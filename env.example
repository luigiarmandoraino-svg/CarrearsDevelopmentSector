from __future__ import annotations

import argparse
import asyncio
import csv
from pathlib import Path

import httpx

from .sources import load_sources


async def check_one(client: httpx.AsyncClient, source):
    try:
        r = await client.get(source.url, timeout=25)
        status = r.status_code
        final_url = str(r.url)
        content_type = r.headers.get("content-type", "")
        if status >= 400:
            result = "BROKEN"
        elif "text/html" in content_type or "json" in content_type or "xml" in content_type:
            result = "OK"
        else:
            result = "CHECK"
        return {"ID": source.id, "Organization": source.organization, "URL": source.url, "Status": status, "Result": result, "Final_URL": final_url, "Content_Type": content_type}
    except Exception as exc:
        return {"ID": source.id, "Organization": source.organization, "URL": source.url, "Status": "", "Result": "ERROR", "Final_URL": "", "Content_Type": "", "Error": repr(exc)}


async def main_async(args):
    sources = load_sources(args.sources)
    limits = httpx.Limits(max_connections=args.concurrency, max_keepalive_connections=args.concurrency)
    headers = {"User-Agent": "Mozilla/5.0 (compatible; LuigiJobBot/1.0)"}
    async with httpx.AsyncClient(follow_redirects=True, headers=headers, limits=limits) as client:
        rows = await asyncio.gather(*(check_one(client, s) for s in sources))
    out = Path(args.output)
    with out.open("w", encoding="utf-8", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=["ID", "Organization", "URL", "Status", "Result", "Final_URL", "Content_Type", "Error"])
        writer.writeheader()
        writer.writerows(rows)
    print(f"Wrote {out}")


def main():
    p = argparse.ArgumentParser(description="Check source career URLs and write a CSV status report.")
    p.add_argument("--sources", default="sources.csv")
    p.add_argument("--output", default="source_access_report.csv")
    p.add_argument("--concurrency", type=int, default=8)
    args = p.parse_args()
    asyncio.run(main_async(args))


if __name__ == "__main__":
    main()
